{
  "name": "shibaita",
  "version": "1.1.2",
  "description": "AIしばいたった。 - Show off how hard you work Claude Code. Local-only token usage aggregator (日本語/English README included)",
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "usage",
    "tokens"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YoshihikoTakashima/shibaita-cli.git"
  },
  "homepage": "https://shibaita.ai",
  "bugs": {
    "url": "https://github.com/YoshihikoTakashima/shibaita-cli/issues"
  },
  "type": "module",
  "bin": {
    "shibaita": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "LICENSE",
    "PRIVACY.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "sync-docs": "cp ../../README.md ../../README.en.md ../../LICENSE ../../PRIVACY.md .",
    "build": "npm run sync-docs && tsup",
    "check": "npm --prefix ../.. test && npm --prefix ../.. run typecheck",
    "prepack": "npm run check && npm run build"
  },
  "dependencies": {
    "picocolors": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@shibaita/core": "*",
    "@shibaita/schema": "*",
    "tsup": "^8.5.1"
  }
}
